{
	"info": {
		"_postman_id": "fb9ef9d5-78ff-4f46-93cb-b09f4fb0a4ef",
		"name": "VideoTube Backend API",
		"description": "Complete Postman collection for the VideoTube backend API.\n\n## Quick Start\n1. Hit **Register User** to create an account\n2. Hit **Login User** — tokens and userId are auto-saved\n3. All other requests will use the saved Bearer token automatically\n\n## Variables\n- `baseUrl` — API base (default: http://localhost:4000/api/v1)\n- `accessToken` — auto-saved on Login / Refresh\n- `refreshToken` — auto-saved on Login / Refresh\n- `userId` — auto-saved on Login\n- `videoId` / `tweetId` / `commentId` / `playlistId` / `channelId` — set manually or via test scripts",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🏥 Healthcheck",
			"item": [
				{
					"name": "Get Healthcheck",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/healthcheck",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"healthcheck"
							]
						},
						"description": "Simple health check — returns 200 OK if the server is alive. No authentication required."
					},
					"response": []
				}
			]
		},
		{
			"name": "👤 Users",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.data && jsonData.data._id) {",
									"    pm.collectionVariables.set(\"userId\", jsonData.data._id);",
									"    console.log(\"✅ userId saved:\", jsonData.data._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "fullname",
									"value": "John Doe",
									"type": "text"
								},
								{
									"key": "email",
									"value": "john.doe@example.com",
									"type": "text"
								},
								{
									"key": "username",
									"value": "johndoe",
									"type": "text"
								},
								{
									"key": "password",
									"value": "securePassword123",
									"type": "text"
								},
								{
									"key": "avatar",
									"type": "file",
									"src": "",
									"description": "(Required) Profile picture"
								},
								{
									"key": "coverImage",
									"type": "file",
									"src": "",
									"description": "(Optional) Channel banner image"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/users/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"register"
							]
						},
						"description": "Registers a new user. Requires multipart/form-data with avatar file (required) and optional coverImage. Auto-saves the returned userId."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.data) {",
									"    if (jsonData.data.accessToken) {",
									"        pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
									"        console.log(\"✅ accessToken saved\");",
									"    }",
									"    if (jsonData.data.refreshToken) {",
									"        pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
									"        console.log(\"✅ refreshToken saved\");",
									"    }",
									"    if (jsonData.data.user && jsonData.data.user._id) {",
									"        pm.collectionVariables.set(\"userId\", jsonData.data.user._id);",
									"        console.log(\"✅ userId saved:\", jsonData.data.user._id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"johndoe\",\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"securePassword123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/users/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"login"
							]
						},
						"description": "Logs in with username/email + password. Auto-saves accessToken, refreshToken, and userId into collection variables for subsequent requests."
					},
					"response": []
				},
				{
					"name": "Logout User",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/logout",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"logout"
							]
						},
						"description": "Logs out the authenticated user — clears cookies and invalidates the refresh token in the database."
					},
					"response": []
				},
				{
					"name": "Refresh Access Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.data) {",
									"    if (jsonData.data.accessToken) {",
									"        pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
									"        console.log(\"✅ accessToken refreshed\");",
									"    }",
									"    if (jsonData.data.refreshToken) {",
									"        pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
									"        console.log(\"✅ refreshToken refreshed\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/users/refresh-token",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"refresh-token"
							]
						},
						"description": "Generates a new access token using a valid refresh token. Auto-saves the new tokens."
					},
					"response": []
				},
